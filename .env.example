PORT=8005

# Postgres connection string (dedicated database per microservice)
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/hdt_identity_provider

# JWT configuration
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS allowed origins (comma-separated). Leave empty to allow all.
CORS_ORIGINS=
